# Payload secret (random 32+ chars)
PAYLOAD_SECRET=change-me

# Database — SQLite. Absolute path on the host filesystem.
# In production on o2switch this MUST be outside the repo and outside web root.
DATABASE_URI=file:./data/payload.db

# Public URL of this Payload instance (admin + API)
PAYLOAD_PUBLIC_SERVER_URL=https://cms.example.com

# Webhook fired on every content change → Astro rebuild
BUILD_WEBHOOK_URL=https://www.example.com/__hooks/rebuild.php
BUILD_WEBHOOK_SECRET=change-me-to-a-long-random-string

# Server
PORT=3000
NODE_ENV=production
